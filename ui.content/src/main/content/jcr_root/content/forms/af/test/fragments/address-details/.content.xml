<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    xmlns:cq="http://www.day.com/jcr/cq/1.0"
    xmlns:jcr="http://www.jcp.org/jcr/1.0"
    xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="cq:Page">
    <jcr:content
        jcr:primaryType="cq:PageContent"
        jcr:title="Address Details Fragment"
        sling:resourceType="test/components/page">
        <root
            jcr:primaryType="nt:unstructured"
            sling:resourceType="wcm/foundation/components/responsivegrid">
            <formContainer
                jcr:primaryType="nt:unstructured"
                sling:resourceType="core/fd/components/form/container/v1/container"
                fieldType="form"
                name="guideContainer">
                <addressDetails
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/fd/components/form/panelcontainer/v1/panelcontainer"
                    jcr:title="Address Details"
                    name="addressDetails">
                    <street
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="core/fd/components/form/textinput/v1/textinput"
                        jcr:title="Street Address"
                        name="streetAddress"
                        required="{Boolean}true"/>
                    <moveInDate
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="core/fd/components/form/datepicker/v1/datepicker"
                        jcr:title="Move-in Date"
                        name="moveInDate"/>
                </addressDetails>
            </formContainer>
        </root>
    </jcr:content>
</jcr:root>
