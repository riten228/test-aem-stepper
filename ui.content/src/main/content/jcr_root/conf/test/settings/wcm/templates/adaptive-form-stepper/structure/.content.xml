<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    xmlns:cq="http://www.day.com/jcr/cq/1.0"
    xmlns:jcr="http://www.jcp.org/jcr/1.0"
    xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="cq:Page">
    <jcr:content
        cq:deviceGroups="[mobile/groups/responsive]"
        cq:template="/conf/test/settings/wcm/templates/adaptive-form-stepper"
        jcr:primaryType="cq:PageContent"
        sling:resourceType="test/components/page">
        <root
            jcr:primaryType="nt:unstructured"
            sling:resourceType="test/components/container"
            layout="responsiveGrid">
            <formContainer
                jcr:primaryType="nt:unstructured"
                sling:resourceType="core/fd/components/form/container/v1/container"
                cq:isContainer="{Boolean}true"
                cq:policy="/conf/test/settings/wcm/policies/test/components/forms/container/stepper-form-container"
                name="guideContainer"
                fieldType="form">
                <wizard
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/fd/components/forms/wizard/v1/wizard"
                    cq:isContainer="{Boolean}true"
                    cq:policy="/conf/test/settings/wcm/policies/test/components/forms/wizard/stepper-policy"
                    fieldType="panel"
                    name="wizard">
                    <items
                        jcr:primaryType="nt:unstructured"
                        cq:isContainer="{Boolean}true"
                        cq:policy="/conf/test/settings/wcm/policies/test/components/forms/wizard/wizard-step-policy"/>
                </wizard>
            </formContainer>
        </root>
        <cq:responsive jcr:primaryType="nt:unstructured">
            <breakpoints jcr:primaryType="nt:unstructured">
                <phone
                    jcr:primaryType="nt:unstructured"
                    title="Smaller Screen"
                    width="{Long}768"/>
                <tablet
                    jcr:primaryType="nt:unstructured"
                    title="Tablet"
                    width="{Long}1200"/>
            </breakpoints>
        </cq:responsive>
    </jcr:content>
</jcr:root>