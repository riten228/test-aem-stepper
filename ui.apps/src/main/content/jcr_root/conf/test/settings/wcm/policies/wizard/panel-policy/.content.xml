<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
          xmlns:cq="http://www.day.com/jcr/cq/1.0"
          xmlns:jcr="http://www.jcp.org/jcr/1.0"
          jcr:primaryType="cq:Policy">

  <!--/* Allow form components inside each step/panel */-->
  <components
    jcr:primaryType="nt:unstructured"
    cq:allowedComponents="[
      'core/fd/components/form/textinput/v1/textinput',
      'core/fd/components/form/emailinput/v1/emailinput',
      'core/fd/components/form/phoneinputv2/v1/phoneinputv2',
      'core/fd/components/form/checkbox/v1/checkbox',
      'core/fd/components/form/radiobutton/v1/radiobutton',
      'core/fd/components/form/datepicker/v1/datepicker',
      'core/fd/components/form/fileupload/v1/fileupload',
      'core/fd/components/form/textfield/v1/textfield',
      'core/fd/components/form/panelcontainer/v1/panelcontainer',
      'core/fd/components/form/formfragment/v1/formfragment',
      'core/fd/components/form/button/v1/button',
      'core/fd/components/form/label/v1/label'
    ]"/>

</jcr:root>
